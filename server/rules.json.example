{
  "_comment_1": "=================================================================",
  "_comment_2": " MINISNAKE DYNAMIC GAME RULES CONFIGURATION",
  "_comment_3": "=================================================================",
  "_comment_4": " USAGE:",
  "_comment_5": " 1. Rename this file from 'rules.json.example' to 'rules.json'.",
  "_comment_6": " 2. Place it in the root directory of your active server.",
  "_comment_7": " 3. Only include the keys you wish to override. Any omitted key",
  "_comment_8": "    will safely fall back to the server's internal hardcoded default.",
  "_comment_9": " 4. Restart the server for the new rules to take effect.",
  "_comment_10": "=================================================================",

  "GameWidth": 25,
  "GameHeight": 20,
  
  "_comment_delay": "Base delay between frames in microseconds (lower = faster)",
  "InitialDelay": 250000.0,
  
  "_comment_speedup": "Multiplier applied to delay after eating a fruit (e.g., 0.985 = 1.5% faster)",
  "SpeedupFactor": 0.985,
  
  "PointsPerFruit": 10,
  "InitialSize": 1,
  
  "_comment_penalty_interval": "Number of steps before losing points (set to 0 to disable penalties)",
  "PenaltyInterval": 10,
  "PenaltyAmount": 1,
  
  "_comment_anti_cheat": "Maximum allowed milliseconds between two frames before triggering a timeout flag",
  "CheatTimeout": 5000,
  
  "_comment_rng_safety": "Max iterations to find an empty spot for a fruit on a crowded board",
  "SpawnFruitMaxAttempts": 10000,

  "_comment_anti_lag": "Minimum Manhattan distance between the snake's head and the new fruit (Masks network latency)",
  "MinFruitDist": 2
}
